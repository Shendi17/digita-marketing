# Configuration de production OVH
# À copier vers .env sur le serveur OVH

# Environnement
APP_ENV=production
APP_DEBUG=false
APP_URL=https://digita.tonyalpha80.com

# Base de données OVH
# IMPORTANT: Remplacez avec vos vraies credentials OVH
DB_HOST=tonyalphzb.mysql.db
DB_NAME=tonyalphzb
DB_USER=tonyalphzb
DB_PASS=VOTRE_MOT_DE_PASSE_BDD

# Sécurité
SESSION_SECURE=true
SESSION_HTTPONLY=true

# Stripe (Production)
STRIPE_PUBLIC_KEY=pk_live_VOTRE_CLE_PUBLIQUE
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_WEBHOOK

# OpenAI
OPENAI_API_KEY=sk-VOTRE_CLE_OPENAI
OPENAI_MODEL=gpt-4

# Webox API
WEBOX_API_URL=https://votre-webox-api.com
WEBOX_API_KEY=VOTRE_CLE_WEBOX

# Email (optionnel)
MAIL_HOST=ssl0.ovh.net
MAIL_PORT=465
MAIL_USERNAME=contact@digita.tonyalpha80.com
MAIL_PASSWORD=VOTRE_MOT_DE_PASSE_EMAIL
MAIL_FROM_ADDRESS=contact@digita.tonyalpha80.com
MAIL_FROM_NAME="Digita Marketing"
