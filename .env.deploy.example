# Configuration de déploiement OVH
# Copiez ce fichier vers .env.deploy et remplissez avec vos credentials

# Informations FTP OVH
FTP_HOST=ftp.cluster0XX.hosting.ovh.net
FTP_USER=votre_user_ftp
FTP_PASS=votre_password_ftp
FTP_PATH=/www/

# SSH OVH (optionnel, pour réparation Git)
SSH_HOST=ssh.cluster0XX.hosting.ovh.net
SSH_USER=votre_user_ssh
SSH_PORT=22
